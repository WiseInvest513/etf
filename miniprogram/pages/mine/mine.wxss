/* pages/mine/mine.wxss */
.page { background: #f0f2f5; min-height: 100vh; }

/* ── Profile Banner ── */
.profile-banner {
  background: linear-gradient(135deg, #0a1628 0%, #1a2d4a 100%);
  padding: 52rpx 40rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

/* 头像按钮 */
.avatar-btn {
  width: 140rpx; height: 140rpx;
  border-radius: 50%;
  padding: 0; margin: 0;
  background: transparent;
  line-height: 1;
}
.avatar-btn::after { border: none; }

.avatar-img {
  width: 140rpx; height: 140rpx;
  border-radius: 50%;
  display: block;
  border: 4rpx solid rgba(255,255,255,0.25);
}
.avatar-empty {
  width: 140rpx; height: 140rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  border: 2rpx dashed rgba(255,255,255,0.3);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 4rpx;
}
.avatar-empty-icon { font-size: 48rpx; }
.avatar-hint { font-size: 18rpx; color: rgba(255,255,255,0.5); }

/* 昵称 */
.nickname-input {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
  width: 400rpx;
}

/* ── Menu ── */
.menu-section {
  background: #fff;
  border-radius: 20rpx;
  margin: 20rpx 20rpx 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.menu-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 30rpx 28rpx;
  border-bottom: 1rpx solid #f5f5f7;
}
.menu-item:last-child { border-bottom: none; }
.menu-item:active { background: #f8f8fa; }
.menu-left  { display: flex; align-items: center; gap: 18rpx; }
.menu-icon  { font-size: 36rpx; }
.menu-label { font-size: 29rpx; font-weight: 600; color: #1d1d1f; }
.menu-right { display: flex; align-items: center; gap: 8rpx; }
.menu-count { font-size: 24rpx; color: #0071e3; font-weight: 600; }
.menu-sub   { font-size: 24rpx; color: #86868b; }
.menu-arrow { font-size: 36rpx; color: #c8c8d0; }

/* ── Disclaimer ── */
.disclaimer {
  margin: 0 20rpx;
  padding: 20rpx;
  background: rgba(0,0,0,0.03);
  border-radius: 12rpx;
}
.disclaimer-text { font-size: 22rpx; color: #b0b0b5; line-height: 1.6; }
