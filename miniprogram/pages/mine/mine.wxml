<view class="page">

  <!-- ── 用户信息卡片 ── -->
  <view class="user-card">

    <!-- 头像（点击可更换） -->
    <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image wx:if="{{avatarUrl}}" class="avatar-img" src="{{avatarUrl}}" mode="aspectFill"/>
      <view wx:else class="avatar-placeholder">
        <text class="avatar-icon">👤</text>
      </view>
      <view class="avatar-edit-badge">换</view>
    </button>

    <view class="user-info">
      <!-- 昵称 -->
      <input
        class="nickname-input"
        type="nickname"
        placeholder="点击设置昵称"
        placeholder-style="color:#c0c0c5;font-size:28rpx"
        value="{{nickName}}"
        bindinput="onNickNameInput"
      />

      <!-- 已登录 -->
      <block wx:if="{{isLoggedIn}}">
        <view class="user-id">ID: {{openid}}</view>
        <view class="user-sync">✓ 自选数据已云端同步</view>
      </block>

      <!-- 登录中 -->
      <block wx:elif="{{loginState === 'loading'}}">
        <view class="user-sub">正在连接微信账户...</view>
      </block>

      <!-- 失败/未登录 -->
      <block wx:else>
        <view class="user-sub">登录后可跨设备同步自选</view>
        <view class="retry-btn" bindtap="retryLogin">
          {{loginState==='fail' ? '重新登录' : '微信一键登录'}}
        </view>
      </block>
    </view>

  </view>

  <!-- ── 功能入口 ── -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goWatchlist">
      <view class="menu-left">
        <text class="menu-icon">⭐</text>
        <text class="menu-label">我的自选</text>
      </view>
      <view class="menu-right">
        <text class="menu-count" wx:if="{{favCount>0}}">{{favCount}}只</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>

    <view class="menu-item" bindtap="goExport">
      <view class="menu-left">
        <text class="menu-icon">📊</text>
        <text class="menu-label">导出数据图</text>
      </view>
      <view class="menu-right">
        <text class="menu-sub">生成4张数据图</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- ── 免责声明 ── -->
  <view class="disclaimer">
    <text class="disclaimer-text">本应用数据仅供参考，不构成任何投资建议。投资有风险，入市须谨慎。</text>
  </view>

  <view style="height:120rpx"/>
</view>
