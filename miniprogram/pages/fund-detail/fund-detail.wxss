.page { background: #f5f5f7; min-height: 100vh; padding-bottom: 60rpx; }

/* ── Hero ── */
.hero {
  background: #fff;
  padding: 28rpx 28rpx 24rpx;
  display: flex; align-items: flex-start;
  justify-content: space-between; gap: 20rpx;
  margin-bottom: 16rpx;
}
.hero-main  { flex: 1; }
.hero-name  { font-size: 30rpx; font-weight: 700; color: #1d1d1f; line-height: 1.4; margin-bottom: 10rpx; }
.hero-code  { font-size: 24rpx; color: #86868b; font-family: monospace; }
.hero-right { text-align: right; flex-shrink: 0; }
.hero-ytd   { font-size: 40rpx; font-weight: 800; letter-spacing: -1rpx; }
.hero-ytd-label { font-size: 22rpx; color: #86868b; margin-top: 6rpx; }

/* ── Section card ── */
.section {
  margin: 0 24rpx 16rpx;
  padding: 24rpx 28rpx;
  border: 1rpx solid #f0f0f5;
}
.section-title {
  font-size: 26rpx; font-weight: 700; color: #86868b;
  text-transform: uppercase; letter-spacing: 1rpx;
  margin-bottom: 20rpx;
}

/* ── Info rows ── */
.info-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f5f5f7;
}
.info-key { font-size: 27rpx; color: #3d3d42; }
.info-val { font-size: 27rpx; font-weight: 600; color: #1d1d1f; }

/* ── Tip card ── */
.tip-card {
  margin: 0 24rpx 16rpx;
  background: rgba(196, 87, 10, 0.06);
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  display: flex; flex-direction: column; gap: 8rpx;
}
.tip-title { font-size: 24rpx; font-weight: 700; color: #c4570a; margin-bottom: 4rpx; }
.tip-text  { font-size: 23rpx; color: #3d3d42; line-height: 1.5; }

/* ── Fav button ── */
.fav-section { padding: 0 24rpx; margin-top: 8rpx; }
.fav-big-btn {
  display: flex; align-items: center; justify-content: center; gap: 12rpx;
  background: #f5f5f7; border-radius: 16rpx;
  padding: 28rpx; border: 2rpx solid #e0e0e5;
}
.fav-big-btn.fav-on { background: rgba(245, 166, 35, 0.1); border-color: #f5a623; }
.fav-big-icon { font-size: 40rpx; color: #c8c8d0; }
.fav-big-btn.fav-on .fav-big-icon { color: #f5a623; }
.fav-big-text { font-size: 28rpx; font-weight: 600; color: #86868b; }
.fav-big-btn.fav-on .fav-big-text { color: #f5a623; }
