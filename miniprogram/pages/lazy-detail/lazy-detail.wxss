/* pages/lazy-detail/lazy-detail.wxss */
.page { background: #f0f2f5; min-height: 100vh; }

/* ── Hero ── */
.hero {
  padding: 48rpx 32rpx 40rpx;
  margin-bottom: 0;
}
.hero-tag {
  display: inline-flex;
  align-items: center;
  border: 1rpx solid;
  border-radius: 100rpx;
  padding: 6rpx 20rpx;
  margin-bottom: 18rpx;
}
.hero-tag-text { font-size: 22rpx; font-weight: 600; letter-spacing: 0.5rpx; }
.hero-name   { font-size: 40rpx; font-weight: 800; color: #fff; margin-bottom: 8rpx; }
.hero-author { font-size: 23rpx; color: rgba(255,255,255,0.5); margin-bottom: 20rpx; }
.hero-desc   { font-size: 27rpx; color: rgba(255,255,255,0.75); line-height: 1.65; }

/* ── Section card ── */
.section-card {
  margin: 16rpx 20rpx 0;
  padding: 28rpx 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}
.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1d1d1f;
  margin-bottom: 20rpx;
}
.section-sub { font-size: 22rpx; font-weight: 400; color: #86868b; margin-left: 8rpx; }

/* ── Metrics grid ── */
.metrics-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}
.metric-item {
  flex: 1;
  min-width: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #f5f5f7;
  border-radius: 14rpx;
  padding: 18rpx 8rpx 14rpx;
  gap: 6rpx;
}
.mval   { font-size: 28rpx; font-weight: 700; color: #1d1d1f; }
.mlabel { font-size: 20rpx; color: #86868b; text-align: center; }

/* ── Pie chart ── */
.pie-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}
.pie-canvas {
  width: 260rpx;
  height: 260rpx;
}

/* ── Alloc rows（合并：色点 + ticker + 标签 + bar + 百分比）── */
.alloc-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f5f5f7;
  gap: 10rpx;
}
.alloc-row:last-child { border-bottom: none; }

.alloc-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.alloc-ticker {
  font-size: 23rpx;
  font-weight: 700;
  min-width: 60rpx;
  flex-shrink: 0;
}
.alloc-label {
  font-size: 21rpx;
  color: #86868b;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.alloc-bar-track {
  width: 120rpx;
  height: 8rpx;
  background: #f0f0f5;
  border-radius: 4rpx;
  overflow: hidden;
  flex-shrink: 0;
}
.alloc-bar-fill { height: 100%; border-radius: 4rpx; }
.alloc-pct {
  font-size: 23rpx;
  font-weight: 600;
  color: #1d1d1f;
  min-width: 52rpx;
  text-align: right;
  flex-shrink: 0;
}

/* ── Year returns ── */
.year-row {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
  gap: 12rpx;
  border-bottom: 1rpx solid #f5f5f7;
}
.year-row:last-child { border-bottom: none; }
.year-label { font-size: 24rpx; color: #86868b; min-width: 80rpx; }
.bar-wrap   { flex: 1; display: flex; align-items: center; }
.bar-fill   { height: 14rpx; border-radius: 7rpx; min-width: 4rpx; }
.year-ret   { font-size: 24rpx; font-weight: 600; min-width: 90rpx; text-align: right; }

/* ── Long desc ── */
.long-desc-para {
  font-size: 26rpx;
  color: #3d3d42;
  line-height: 1.75;
  margin-bottom: 18rpx;
}
.long-desc-para:last-child { margin-bottom: 0; }

/* ── Colors ── */
.text-green { color: #1a9e4a; }
.text-red   { color: #d93025; }
