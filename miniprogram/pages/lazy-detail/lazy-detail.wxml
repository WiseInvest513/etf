<!-- pages/lazy-detail/lazy-detail.wxml -->
<view class="page" wx:if="{{p}}">

  <!-- ── Hero ── -->
  <view class="hero" style="background: linear-gradient(135deg, #0d1c35 0%, {{p.color}}55 100%);">
    <view class="hero-tag" style="background:{{p.color}}22;border-color:{{p.color}}66">
      <text class="hero-tag-text" style="color:{{p.color}}">{{p.nameEn}}</text>
    </view>
    <view class="hero-name">{{p.name}}</view>
    <view class="hero-author">by {{p.author}}</view>
    <view class="hero-desc">{{p.desc}}</view>
  </view>

  <!-- ── 关键指标 ── -->
  <view class="section-card">
    <view class="section-title">关键指标 <text class="section-sub">2017–2025</text></view>
    <view class="metrics-grid">
      <view class="metric-item">
        <text class="mval {{p.cagr>=0?'text-green':'text-red'}}">{{p.cagr>=0?'+':''}}{{p.cagr}}%</text>
        <text class="mlabel">年化收益</text>
      </view>
      <view class="metric-item metric-item-accent">
        <text class="mval text-red">{{p.maxDrawdown}}%</text>
        <text class="mlabel">最大回撤</text>
      </view>
      <view class="metric-item">
        <text class="mval">{{p.sharpe}}</text>
        <text class="mlabel">夏普比率</text>
      </view>
      <view class="metric-item">
        <text class="mval">{{p.sortino}}</text>
        <text class="mlabel">索提诺</text>
      </view>
      <view class="metric-item">
        <text class="mval">{{p.volatility}}%</text>
        <text class="mlabel">年化波动</text>
      </view>
    </view>
  </view>

  <!-- ── 资产配置 ── -->
  <view class="section-card">
    <view class="section-title">资产配置</view>

    <!-- 环形图居中 -->
    <view class="pie-wrap">
      <canvas type="2d" id="allocPie" class="pie-canvas"/>
    </view>

    <!-- 合并的配置行（色点 + ticker + 标签 + 进度条 + 百分比） -->
    <view wx:for="{{allocsLabeled}}" wx:key="ticker" class="alloc-row">
      <view class="alloc-dot" style="background:{{item.color}}"/>
      <text class="alloc-ticker" style="color:{{item.color}}">{{item.ticker}}</text>
      <text class="alloc-label">{{item.labelShort}}</text>
      <view class="alloc-bar-track">
        <view class="alloc-bar-fill" style="width:{{item.pct}}%;background:{{item.color}}"/>
      </view>
      <text class="alloc-pct">{{item.pct}}%</text>
    </view>
  </view>

  <!-- ── 逐年收益 ── -->
  <view class="section-card">
    <view class="section-title">逐年收益</view>
    <view wx:for="{{yearReturns}}" wx:key="year" class="year-row">
      <text class="year-label">{{item.year}}</text>
      <view class="bar-wrap">
        <view
          class="bar-fill"
          style="width:{{item.barW}}rpx;background:{{item.positive?'#1a9e4a':'#d93025'}}"
        />
      </view>
      <text class="year-ret {{item.positive?'text-green':'text-red'}}">{{item.display}}</text>
    </view>
  </view>

  <!-- ── 组合解析 ── -->
  <view class="section-card">
    <view class="section-title">组合解析</view>
    <view wx:for="{{p.longDesc}}" wx:key="*this" class="long-desc-para">{{item}}</view>
  </view>

  <view style="height:60rpx"/>
</view>
