.page { background: #f5f5f7; min-height: 100vh; }

/* ── Sub-tabs ── */
.sub-tabs-bar {
  background: #fff;
  border-bottom: 1rpx solid #e8e8ed;
  position: sticky; top: 0; z-index: 20;
}
.sub-tabs-scroll { width: 100%; }
.sub-tabs-inner  { display: flex; width: 100%; }
.sub-tab {
  flex: 1;
  display: flex; align-items: center; justify-content: center;
  padding: 24rpx 0; font-size: 28rpx; color: #86868b;
  font-weight: 500;
  border-bottom: 4rpx solid transparent;
}
.sub-tab.active { color: #0071e3; font-weight: 700; border-bottom-color: #0071e3; }

/* ── Toolbar ── */
.toolbar-wrap { background: #f5f5f7; padding: 14rpx 20rpx 10rpx; }
.search-row   { display: flex; align-items: center; gap: 12rpx; }
.search-box {
  flex: 1;
  display: flex; align-items: center;
  background: #fff; border-radius: 12rpx;
  padding: 14rpx 18rpx;
  border: 1rpx solid #e8e8ed;
}
.s-icon  { font-size: 26rpx; margin-right: 10rpx; }
.s-input { flex: 1; font-size: 26rpx; color: #1d1d1f; }
.s-clear { font-size: 22rpx; color: #86868b; padding: 0 4rpx; }

/* 筛选按钮 */
.filter-btn {
  display: flex; align-items: center; gap: 6rpx;
  background: #fff; border: 1rpx solid #e0e0e5;
  border-radius: 12rpx; padding: 14rpx 22rpx;
  flex-shrink: 0; position: relative;
}
.filter-btn-on { background: #0071e3; border-color: #0071e3; }
.filter-icon   { font-size: 26rpx; color: #3d3d42; }
.filter-btn-on .filter-icon  { color: #fff; }
.filter-label  { font-size: 26rpx; color: #3d3d42; font-weight: 500; }
.filter-btn-on .filter-label { color: #fff; font-weight: 600; }
.filter-badge {
  position: absolute; top: -10rpx; right: -10rpx;
  background: #ff3b30; color: #fff;
  font-size: 18rpx; font-weight: 700;
  min-width: 30rpx; height: 30rpx; border-radius: 20rpx;
  display: flex; align-items: center; justify-content: center;
  padding: 0 6rpx;
}

/* ── Fund rows ── */
.list-wrap { background: #fff; margin-top: 12rpx; }

.fund-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid #f2f2f7;
  min-height: 100rpx;
}
.fund-row:active { background: #f8f8fa; }

.row-left  { flex: 1; margin-right: 12rpx; overflow: hidden; }
.row-name  {
  font-size: 27rpx; font-weight: 600; color: #1d1d1f;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  display: block; margin-bottom: 10rpx;
}
.row-sub   { display: flex; align-items: center; gap: 8rpx; flex-wrap: wrap; }
.row-code  { font-size: 22rpx; color: #86868b; font-family: monospace; }
.row-limit { font-size: 22rpx; color: #b0b0b5; }

.row-right { display: flex; align-items: center; gap: 8rpx; flex-shrink: 0; }
.row-ytd   { font-size: 30rpx; font-weight: 700; letter-spacing: -0.5rpx; white-space: nowrap; }

/* ── Fav ── */
.fav-btn  { padding: 8rpx; }
.fav-icon { font-size: 34rpx; color: #d0d0d5; }
.fav-on   { color: #f5a623; }

/* ── Skeleton ── */
.skeleton-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 24rpx; border-bottom: 1rpx solid #f2f2f7;
}
.sk-left { flex: 1; margin-right: 16rpx; }

/* ── 筛选底部弹层 ── */
.sheet-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.45); z-index: 100;
}
.sheet {
  position: fixed; left: 0; right: 0; bottom: 0;
  background: #fff; border-radius: 24rpx 24rpx 0 0;
  z-index: 101;
  max-height: 86vh;
  display: flex; flex-direction: column;
}

.sheet-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f5;
  flex-shrink: 0;
}
.sheet-title { font-size: 32rpx; font-weight: 700; color: #1d1d1f; }
.sheet-close { font-size: 36rpx; color: #86868b; padding: 0 8rpx; }

.sheet-body  { flex: 1; overflow-y: auto; padding: 0 0 20rpx; }

/* ── 筛选分组 ── */
.filter-section { padding: 24rpx 28rpx 8rpx; }
.filter-sec-title {
  font-size: 24rpx; font-weight: 600; color: #86868b;
  display: block; margin-bottom: 16rpx;
  text-transform: uppercase; letter-spacing: 1rpx;
}

.filter-opts-wrap {
  display: flex; flex-wrap: wrap; gap: 14rpx;
}
.filter-opt {
  padding: 14rpx 24rpx;
  border: 1rpx solid #e0e0e5; border-radius: 10rpx;
  font-size: 26rpx; color: #3d3d42;
  background: #fafafa;
  transition: all 0.15s;
}
.filter-opt-on {
  background: #0071e3; border-color: #0071e3;
  color: #fff; font-weight: 600;
}

/* ── 底部按钮 ── */
.sheet-footer {
  display: flex; gap: 20rpx;
  padding: 20rpx 28rpx 40rpx;
  border-top: 1rpx solid #f0f0f5;
  flex-shrink: 0;
}
.sheet-reset {
  flex: 1; text-align: center;
  padding: 24rpx 0; border-radius: 14rpx;
  font-size: 28rpx; font-weight: 600; color: #3d3d42;
  background: #f0f0f5;
}
.sheet-apply {
  flex: 2; text-align: center;
  padding: 24rpx 0; border-radius: 14rpx;
  font-size: 28rpx; font-weight: 700; color: #fff;
  background: #0071e3;
}
.sheet-reset:active { opacity: 0.7; }
.sheet-apply:active { opacity: 0.85; }
