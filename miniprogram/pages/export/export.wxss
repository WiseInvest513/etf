/* pages/export/export.wxss */
.page { min-height: 100vh; background: #f5f5f7; padding: 24rpx; }

/* ── Intro ── */
.intro-card {
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #f0f0f5;
}
.intro-title { font-size: 30rpx; font-weight: 700; color: #1d1d1f; margin-bottom: 10rpx; }
.intro-desc  { font-size: 26rpx; color: #86868b; line-height: 1.6; }

/* ── Generate button ── */
.btn-wrap { display: flex; justify-content: center; margin-bottom: 28rpx; }
.gen-btn {
  background: #0071e3;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  padding: 26rpx 80rpx;
  border-radius: 100rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 113, 227, 0.3);
}
.gen-btn-loading {
  background: #86868b;
  box-shadow: none;
}

/* ── Hidden canvas ── */
.canvas-hidden  { position: fixed; top: -9999rpx; left: -9999rpx; opacity: 0; pointer-events: none; }
.offscreen-canvas { width: 750rpx; height: 1rpx; }

/* ── Preview ── */
.preview-section { }
.preview-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.preview-title  { font-size: 28rpx; font-weight: 700; color: #1d1d1f; }
.save-all-btn {
  background: #1a9e4a;
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 12rpx 32rpx;
  border-radius: 100rpx;
}

.preview-item   { margin-bottom: 24rpx; }
.preview-label  { font-size: 24rpx; color: #86868b; margin-bottom: 10rpx; }
.preview-img    {
  width: 100%;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.12);
}

/* ── Toast ── */
.toast {
  position: fixed;
  bottom: 180rpx;
  left: 50%;
  transform: translateX(-50%);
  padding: 20rpx 48rpx;
  border-radius: 100rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  white-space: nowrap;
  z-index: 999;
}
.toast-ok  { background: rgba(26, 158, 74, 0.92); }
.toast-err { background: rgba(217, 48, 37, 0.92); }
