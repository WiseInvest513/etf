<!-- pages/export/export.wxml -->
<view class="page">

  <!-- ── 说明 ── -->
  <view class="intro-card card">
    <view class="intro-title">📊 一键导出数据图</view>
    <view class="intro-desc">生成4张数据图片（纳指/标普/ETF/主动），保存到相册后可分享。</view>
  </view>

  <!-- ── 生成按钮 ── -->
  <view class="btn-wrap">
    <view
      class="gen-btn {{generating?'gen-btn-loading':''}}"
      bindtap="{{generating?'':'generateAll'}}"
    >
      <text wx:if="{{generating}}">正在生成…</text>
      <text wx:else>生成数据图</text>
    </view>
  </view>

  <!-- ── 隐藏 Canvas（用于绘制）── -->
  <view class="canvas-hidden">
    <canvas type="2d" id="canvas-nasdaq" class="offscreen-canvas"/>
    <canvas type="2d" id="canvas-sp500"  class="offscreen-canvas"/>
    <canvas type="2d" id="canvas-etf"    class="offscreen-canvas"/>
    <canvas type="2d" id="canvas-active" class="offscreen-canvas"/>
  </view>

  <!-- ── 预览 & 保存 ── -->
  <view wx:if="{{images.length>0}}" class="preview-section">
    <view class="preview-header">
      <text class="preview-title">预览（点图片保存到相册）</text>
      <view class="save-all-btn" bindtap="saveAll">全部保存</view>
    </view>
    <view wx:for="{{images}}" wx:key="title" class="preview-item">
      <view class="preview-label">{{item.title}}</view>
      <image
        class="preview-img"
        src="{{item.tempFilePath}}"
        mode="widthFix"
        bindtap="saveImage"
        data-path="{{item.tempFilePath}}"
      />
    </view>
  </view>

  <!-- ── Toast ── -->
  <view wx:if="{{toast}}" class="toast {{toast.ok?'toast-ok':'toast-err'}}">
    {{toast.msg}}
  </view>

  <view style="height:120rpx"/>
</view>
