/* pages/watchlist/watchlist.wxss */
.page { min-height: 100vh; background: #f0f2f5; }

.content { padding: 0 20rpx; }

.total-line {
  padding: 20rpx 4rpx 4rpx;
}
.total-text { font-size: 24rpx; color: #86868b; }

/* ── Group header ── */
.group-header {
  font-size: 24rpx; font-weight: 700;
  color: #0071e3;
  padding: 18rpx 4rpx 10rpx;
  letter-spacing: 0.5rpx;
}

/* ── Fund card ── */
.fav-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 14rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

/* 顶部：名称区 + 收益区 */
.card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 22rpx 24rpx 18rpx;
  gap: 12rpx;
}
.card-name-area { flex: 1; min-width: 0; }
.fav-name {
  font-size: 27rpx; font-weight: 600; color: #1d1d1f;
  line-height: 1.4; margin-bottom: 8rpx;
  display: block;
}
.card-meta {
  display: flex; align-items: center; gap: 10rpx; flex-wrap: wrap;
}
.fav-code { font-size: 22rpx; color: #86868b; font-family: monospace; }

/* 年化收益区 */
.card-ytd-area {
  display: flex; flex-direction: column; align-items: flex-end;
  flex-shrink: 0;
}
.fav-ytd  { font-size: 32rpx; font-weight: 700; letter-spacing: -0.5rpx; white-space: nowrap; }
.ytd-label{ font-size: 20rpx; color: #86868b; margin-top: 2rpx; }

/* 分割线 */
.card-divider { height: 1rpx; background: #f5f5f7; }

/* 底部指标行 */
.card-stats {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  gap: 0;
}
.stat-item {
  flex: 1;
  display: flex; flex-direction: column; align-items: center; gap: 4rpx;
}
.stat-limit { flex: 1.3; }
.stat-index { flex: 2; }
.stat-val   { font-size: 23rpx; font-weight: 600; color: #1d1d1f; }
.stat-val-sm{ font-size: 20rpx; }
.stat-label { font-size: 18rpx; color: #86868b; }
.stat-sep   { width: 1rpx; height: 32rpx; background: #f0f0f5; flex-shrink: 0; }

/* 移除按钮 */
.remove-btn  { padding: 10rpx 0 10rpx 16rpx; flex-shrink: 0; }
.remove-icon { font-size: 26rpx; color: #d0d0d5; }
.remove-btn:active .remove-icon { color: #d93025; }

/* ── Badges ── */
.badge {
  font-size: 20rpx; font-weight: 600;
  padding: 3rpx 12rpx; border-radius: 6rpx;
}
.badge-open      { background: #e8f5ec; color: #1a9e4a; }
.badge-suspended { background: #fdecea; color: #d93025; }
.badge-orange    { background: #fff3e0; color: #e65100; }

/* ── Empty state ── */
.empty-wrap {
  display: flex; align-items: center; justify-content: center;
  height: 60vh;
}
.empty-state {
  display: flex; flex-direction: column; align-items: center; gap: 12rpx;
}
.empty-icon  { font-size: 80rpx; }
.empty-title { font-size: 30rpx; font-weight: 600; color: #3d3d42; }
.empty-sub   { font-size: 26rpx; color: #86868b; }
.go-btn {
  margin-top: 16rpx;
  background: #0071e3; color: #fff;
  padding: 22rpx 64rpx; border-radius: 100rpx;
  font-size: 30rpx; font-weight: 600;
}

/* ── Colors ── */
.text-green { color: #1a9e4a; }
.text-red   { color: #d93025; }
