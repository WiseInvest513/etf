/* pages/lazy/lazy.wxss */
.page { min-height: 100vh; background: #f0f2f5; }

/* ── Banner ── */
.banner {
  background: linear-gradient(135deg, #0a1628 0%, #1a2d4a 100%);
  padding: 44rpx 32rpx 36rpx;
}
.banner-title { font-size: 44rpx; font-weight: 800; color: #fff; margin-bottom: 8rpx; }
.banner-sub   { font-size: 24rpx; color: rgba(255,255,255,0.5); }

/* ── List ── */
.list { padding: 20rpx 20rpx 0; }

/* ── Card ── */
.portfolio-card {
  margin-bottom: 20rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: #fff;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}
.portfolio-card:active { opacity: 0.9; transform: scale(0.99); }

/* 卡头（深色渐变 + 组合色） */
.card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 24rpx 20rpx;
}
.head-left { flex: 1; overflow: hidden; }
.port-name {
  font-size: 30rpx; font-weight: 800; color: #fff;
  margin-bottom: 4rpx;
}
.port-name-en { font-size: 21rpx; color: rgba(255,255,255,0.5); }

/* 年化徽章 */
.cagr-badge {
  display: flex; flex-direction: column; align-items: center;
  border: 1rpx solid;
  border-radius: 14rpx;
  padding: 10rpx 18rpx;
  flex-shrink: 0; margin-left: 16rpx;
  gap: 2rpx;
}
.cagr-val   { font-size: 28rpx; font-weight: 800; }
.cagr-label { font-size: 18rpx; color: rgba(255,255,255,0.55); }
.text-green-lt { color: #4ade80; }
.text-red-lt   { color: #f87171; }

/* 卡片主体 */
.card-body { padding: 16rpx 24rpx 20rpx; }

/* 指标行 */
.metrics-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f0f0f5;
}
.metric {
  flex: 1;
  display: flex; flex-direction: column; align-items: center; gap: 4rpx;
}
.metric-val   { font-size: 26rpx; font-weight: 700; color: #1d1d1f; letter-spacing: -0.5rpx; }
.metric-label { font-size: 19rpx; color: #86868b; }
.metric-sep   { width: 1rpx; height: 34rpx; background: #e8e8ed; flex-shrink: 0; }

/* 持仓 pills */
.alloc-row { display: flex; flex-wrap: wrap; gap: 8rpx; }
.alloc-pill {
  display: flex; align-items: center; gap: 5rpx;
  border: 1rpx solid;
  border-radius: 8rpx;
  padding: 5rpx 12rpx;
}
.alloc-ticker { font-size: 20rpx; font-weight: 700; }
.alloc-pct    { font-size: 20rpx; color: #3d3d42; }

/* ── Colors ── */
.text-green { color: #1a9e4a; }
.text-red   { color: #d93025; }
