/* pages/lazy/lazy.wxss */
.page { min-height: 100vh; background: #f0f2f5; }

.header-tip {
  font-size: 24rpx;
  color: #86868b;
  padding: 20rpx 28rpx 12rpx;
}

.list { padding: 0 20rpx 0; }

/* ── Portfolio card ── */
.portfolio-card {
  display: flex;
  align-items: stretch;
  margin-bottom: 20rpx;
  padding: 0;
  overflow: hidden;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.07);
}
.portfolio-card:active { opacity: 0.92; }

.color-bar {
  width: 10rpx;
  flex-shrink: 0;
}
.card-body {
  flex: 1;
  padding: 24rpx 20rpx 20rpx;
  overflow: hidden;
}

/* 名称行 */
.name-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 2rpx;
}
.port-name    { font-size: 30rpx; font-weight: 700; color: #1d1d1f; }
.port-name-en { font-size: 21rpx; color: #86868b; }
.author-text  { font-size: 21rpx; color: #b0b0b5; margin-bottom: 16rpx; }

/* 指标行 */
.metrics-row {
  display: flex;
  align-items: center;
  margin-bottom: 14rpx;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #f0f0f5;
}
.metric {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 14rpx 0;
  background: #fafafa;
}
.metric-val   { font-size: 26rpx; font-weight: 700; letter-spacing: -0.5rpx; }
.metric-label { font-size: 19rpx; color: #86868b; }
.metric-divider {
  width: 1rpx;
  height: 40rpx;
  background: #e8e8ed;
  flex-shrink: 0;
}

/* 简介 */
.port-desc {
  font-size: 24rpx;
  color: #6e6e73;
  line-height: 1.6;
  margin-bottom: 14rpx;
}

/* 持仓 pills */
.alloc-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
.alloc-pill {
  display: flex;
  align-items: center;
  gap: 5rpx;
  border: 1rpx solid;
  border-radius: 8rpx;
  padding: 5rpx 12rpx;
}
.alloc-ticker { font-size: 20rpx; font-weight: 700; }
.alloc-pct    { font-size: 20rpx; color: #3d3d42; }

/* 箭头 */
.arrow {
  display: flex;
  align-items: center;
  padding: 0 20rpx 0 6rpx;
  font-size: 38rpx;
  color: #c8c8d0;
  flex-shrink: 0;
}
