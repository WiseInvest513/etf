/* pages/lazy/lazy.wxss */
.page { min-height: 100vh; background: #f5f5f7; }

.header-tip {
  font-size: 24rpx;
  color: #86868b;
  padding: 20rpx 28rpx 8rpx;
}

.list { padding: 8rpx 24rpx 0; }

/* ── Portfolio card ── */
.portfolio-card {
  display: flex;
  align-items: stretch;
  margin-bottom: 18rpx;
  padding: 0;
  overflow: hidden;
  border: 1rpx solid #f0f0f5;
}
.color-bar {
  width: 8rpx;
  flex-shrink: 0;
}
.card-body {
  flex: 1;
  padding: 24rpx 20rpx 20rpx;
}

.name-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  margin-bottom: 4rpx;
}
.port-name    { font-size: 30rpx; font-weight: 700; color: #1d1d1f; }
.port-name-en { font-size: 22rpx; color: #86868b; }
.author-text  { font-size: 22rpx; color: #b0b0b5; margin-bottom: 18rpx; }

/* 指标行 */
.metrics-row {
  display: flex;
  align-items: center;
  gap: 0;
  margin-bottom: 16rpx;
  background: #f8f8fa;
  border-radius: 10rpx;
  padding: 12rpx 0;
}
.metric {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}
.metric-val   { font-size: 26rpx; font-weight: 700; letter-spacing: -0.5rpx; }
.metric-label { font-size: 20rpx; color: #86868b; }
.metric-divider {
  width: 1rpx;
  height: 36rpx;
  background: #e0e0e5;
  flex-shrink: 0;
}

/* 简介 */
.port-desc {
  font-size: 24rpx;
  color: #3d3d42;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

/* 持仓 pills */
.alloc-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}
.alloc-pill {
  display: flex;
  align-items: center;
  gap: 6rpx;
  border: 1rpx solid;
  border-radius: 8rpx;
  padding: 6rpx 12rpx;
}
.alloc-ticker { font-size: 20rpx; font-weight: 700; }
.alloc-pct    { font-size: 20rpx; color: #3d3d42; }

/* 箭头 */
.arrow {
  display: flex;
  align-items: center;
  padding: 0 20rpx 0 8rpx;
  font-size: 40rpx;
  color: #c8c8d0;
  flex-shrink: 0;
}
