<!-- pages/lazy/lazy.wxml -->
<view class="page">

  <!-- ── 顶部 Banner ── -->
  <view class="banner">
    <view class="banner-title">懒人组合</view>
    <view class="banner-sub">{{portfolios.length}} 个经典资产配置方案 · 长期持有</view>
  </view>

  <view class="list">
    <view
      class="portfolio-card"
      wx:for="{{portfolios}}" wx:key="id"
      bindtap="goDetail"
      data-id="{{item.id}}"
    >
      <!-- 卡片头部（渐变色块）-->
      <view class="card-head" style="background: linear-gradient(135deg, #0d1c35 0%, {{item.color}}60 100%);">
        <view class="head-left">
          <view class="port-name">{{item.name}}</view>
          <view class="port-name-en">{{item.nameEn}}</view>
        </view>
        <view class="cagr-badge" style="background:{{item.color}}30;border-color:{{item.color}}60">
          <text class="cagr-val {{item.cagr>=0?'text-green-lt':'text-red-lt'}}">{{item.cagr>=0?'+':''}}{{item.cagr}}%</text>
          <text class="cagr-label">年化</text>
        </view>
      </view>

      <!-- 卡片主体 -->
      <view class="card-body">

        <!-- 三项指标 -->
        <view class="metrics-row">
          <view class="metric">
            <text class="metric-val text-red">{{item.maxDrawdown}}%</text>
            <text class="metric-label">最大回撤</text>
          </view>
          <view class="metric-sep"/>
          <view class="metric">
            <text class="metric-val">{{item.sharpe}}</text>
            <text class="metric-label">夏普比率</text>
          </view>
          <view class="metric-sep"/>
          <view class="metric">
            <text class="metric-val">{{item.volatility}}%</text>
            <text class="metric-label">年化波动</text>
          </view>
        </view>

        <!-- 持仓 pills -->
        <view class="alloc-row">
          <view
            class="alloc-pill"
            wx:for="{{item.allocs}}" wx:key="*this"
            wx:for-item="a"
            style="background:{{item.color}}15;border-color:{{item.color}}35"
          >
            <text class="alloc-ticker" style="color:{{item.color}}">{{a[0]}}</text>
            <text class="alloc-pct">{{a[1]}}%</text>
          </view>
        </view>

      </view>
    </view>
  </view>

  <view style="height:120rpx"/>
</view>
