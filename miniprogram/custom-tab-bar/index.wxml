<view class="tabbar">
  <view class="tabbar-border"/>
  <view
    wx:for="{{list}}" wx:key="index"
    class="tab-item {{selected===index?'tab-active':''}}"
    bindtap="onSwitch"
    data-path="{{item.path}}"
    data-index="{{index}}"
  >
    <view class="tab-indicator {{selected===index?'indicator-on':''}}"/>
    <text class="tab-icon">{{selected===index ? item.iconSel : item.icon}}</text>
    <text class="tab-label">{{item.label}}</text>
  </view>
</view>
