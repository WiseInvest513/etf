{
  "build": {
    "env": {
      "NODE_VERSION": "22"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "crons": [
    { "path": "/api/cron/refresh",   "schedule": "30 1 * * *"    },
    { "path": "/api/cron/prem",      "schedule": "0 2 * * *"     },
    { "path": "/api/cron/qdii",      "schedule": "55 7 * * 1-5"  },
    { "path": "/api/cron/qdii",      "schedule": "25 13 * * 1-5" },
    { "path": "/api/cron/qdii",      "schedule": "55 19 * * 1-5" },
    { "path": "/api/cron/post_snap", "schedule": "30 21 * * 1-5" }
  ]
}
